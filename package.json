{
  "name": "axite-mcp-template",
  "version": "2.0.0",
  "private": true,
  "description": "Production-ready monorepo template for building ChatGPT MCP apps with standalone server and Next.js frontend",
  "keywords": ["mcp", "chatgpt", "openai", "template", "starter", "nextjs", "monorepo", "oauth"],
  "author": "Axite Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/axite-mcp-template"
  },
  "homepage": "https://github.com/yourusername/axite-mcp-template#readme",
  "bugs": {
    "url": "https://github.com/yourusername/axite-mcp-template/issues"
  },
  "scripts": {
    "dev": "pnpm run --parallel dev:server dev:web",
    "dev:server": "pnpm --filter @axite/server dev",
    "dev:web": "pnpm --filter @axite/web dev",
    "build": "pnpm run build:shared && pnpm run --parallel build:server build:web",
    "build:shared": "pnpm --filter @axite/shared build",
    "build:server": "pnpm --filter @axite/server build",
    "build:web": "pnpm --filter @axite/web build",
    "start": "pnpm run --parallel start:server start:web",
    "start:server": "pnpm --filter @axite/server start",
    "start:web": "pnpm --filter @axite/web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:shared": "pnpm --filter @axite/shared test",
    "test:server": "pnpm --filter @axite/server test",
    "test:web": "pnpm --filter @axite/web test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @axite/web test:e2e",
    "db:generate": "pnpm --filter @axite/server db:generate",
    "db:migrate": "pnpm --filter @axite/server db:migrate",
    "db:push": "pnpm --filter @axite/server db:push",
    "db:studio": "pnpm --filter @axite/server db:studio",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/web/.next",
    "prepare": "pnpm build:shared"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
